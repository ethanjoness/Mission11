@page
@model BookstoreApp.Pages.CartModel
@using BookstoreApp.Models

<h2>Your Shopping Cart</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
    <tr>
        <th>Item</th>
        <th>Quantity</th>
        <th class="text-end">Price</th>
        <th class="text-end">Subtotal</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var line in Model.Cart?.Lines ?? Enumerable.Empty<CartLine>())
    {
        <tr>
            <td class="text-start">@line.Book.Title</td>
            <td class="text-center">@line.Quantity</td>
            <td class="text-end">@line.Book.Price.ToString("c")</td>
            <td class="text-end">
                @((line.Quantity * line.Book.Price).ToString("c"))
            </td>
        </tr>
    }
    </tbody>
    <tfoot>
    <tr>
        <td colspan="3" class="text-end fw-bold">Total:</td>
        <td class="text-end fw-bold">
            @Model.Cart?.CalculateTotal().ToString("c")
        </td>
    </tr>
    </tfoot>
</table>

<div class="text-center mt-3">
    <a class="btn btn-primary" href="@Model.ReturnUrl">Continue Shopping</a>
    
    <button class="btn btn-success" onclick="alert('Checkout functionality coming in the next assignment!')">
        Checkout
    </button>
</div>