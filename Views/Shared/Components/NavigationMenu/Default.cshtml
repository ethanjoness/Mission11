@model IEnumerable<string>

<div class="d-grid gap-2">
    <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="Home" asp-route-category="">
        Home
    </a>

    @foreach (string c in Model)
    {
        <a class="btn @(c == ViewBag.SelectedCategory ? "btn-primary" : "btn-outline-secondary")"
           asp-action="Index" asp-controller="Home"
           asp-route-category="@c" asp-route-pageNum="1">
            @c
        </a>
    }
</div>