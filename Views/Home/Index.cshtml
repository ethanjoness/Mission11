@model BookListViewModel

<div class="row">
    <div class="col-3">
        <vc:navigation-menu />
    </div>

    <div class="col-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>@(Model.CurrentCategory ?? "All Books")</h2>
            
            <form method="get" class="d-flex align-items-center">
                <label class="me-2">Show:</label>
                <select name="pageSize" class="form-select w-auto" onchange="this.form.submit()">
                    <option value="5" selected="@(Model.PagingInfo.ItemsPerPage == 5)">5</option>
                    <option value="10" selected="@(Model.PagingInfo.ItemsPerPage == 10)">10</option>
                </select>
                <input type="hidden" name="sortOrder" value="@Model.CurrentSort" />
                <input type="hidden" name="category" value="@Model.CurrentCategory" />
            </form>
        </div>

        @foreach (var b in Model.Books)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-9">
                            <h4 class="card-title">
                                @b.Title
                                <span class="badge bg-info text-dark fs-6 rounded-pill">@b.Category</span>
                            </h4>
                            <h6 class="card-subtitle mb-2 text-muted">@b.Author | @b.Publisher</h6>
                            <p class="card-text mb-1"><small><strong>ISBN:</strong> @b.ISBN | <strong>Pages:</strong> @b.PageCount</small></p>
                        </div>
                        <div class="col-3 text-end">
                            <h4 class="text-success">@b.Price.ToString("c")</h4>
                            
                            <form method="post" asp-page="/Cart">
                                <input type="hidden" name="bookId" value="@b.BookID" />
                                <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
                                
                                <button type="submit" class="btn btn-primary" 
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Add this book to your cart!">
                                    Add to Cart
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }

        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagingInfo.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNum="@i"
                           asp-route-pageSize="@Model.PagingInfo.ItemsPerPage"
                           asp-route-sortOrder="@Model.CurrentSort"
                           asp-route-category="@Model.CurrentCategory">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>